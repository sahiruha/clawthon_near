# NEAR AI Cloud (https://cloud.near.ai)
# クーポンコード `NEAR-HACK-TOKYO` で $5 分のクレジットを取得
NEAR_AI_API_KEY=
NEAR_AI_BASE_URL=https://cloud-api.near.ai/v1
NEAR_AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# NEAR testnet (https://near-faucet.io/)
NEAR_NETWORK=testnet
NEAR_NODE_URL=https://rpc.testnet.near.org

# Orchestrator account (送金元)
NEAR_ORCHESTRATOR_ACCOUNT=
NEAR_ORCHESTRATOR_PRIVATE_KEY=

# Sub-agent receiving accounts
NEAR_FLIGHT_AGENT_ACCOUNT=
NEAR_HOTEL_AGENT_ACCOUNT=
NEAR_LOCAL_GUIDE_AGENT_ACCOUNT=

# XRPL testnet (https://xrpl.org/xrp-testnet-faucet.html)
XRPL_NETWORK=wss://s.altnet.rippletest.net:51233
XRPL_ORCHESTRATOR_SEED=
XRPL_LOCAL_GUIDE_ADDRESS=

# IronClaw local (gateway はデフォルト 127.0.0.1:3000)
IRONCLAW_BASE_URL=http://127.0.0.1:3000
# バイナリのフルパス (subprocess 呼び出し用)
IRONCLAW_BIN=/path/to/ironclaw-aarch64-apple-darwin/ironclaw
